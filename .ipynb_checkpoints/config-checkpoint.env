params={'model__n_estimators': [800, 500, 300], 'model__learning_rate': [0.01, 0.1, 1],'model__reg_lambda': [0.1, 1, 5, 10]} # other params include learning_rate and reg_lambda
folds= 5

# this param is to be used after training. Mention the experiment name whose model needs to be used for prediction
model_exp_for_pred=experiment_20260604_035205